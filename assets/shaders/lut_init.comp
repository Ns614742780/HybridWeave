#version 450
layout(local_size_x = 64, local_size_y = 1, local_size_z = 1) in;

// output LUT 256x1
layout(set = 0, binding = 0, rgba16f) uniform writeonly image2D uLutOut;

void main()
{
    uint i = gl_GlobalInvocationID.x;
    if (i >= 256u) return;

    float x = float(i) / 255.0;
    imageStore(uLutOut, ivec2(int(i), 0), vec4(x, x, x, 1.0));
}
